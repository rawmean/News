"{    \"translations\": [        {            \"english_version\": \"Castro and five others are charged with planning to kill US citizens, murder, and destroying aircraft.\",            \"english_title\": \"Charges Against Castro\",            \"translated_version\": \"Castro y cinco m\u00e1s est\u00e1n acusados de planear matar a ciudadanos de Estados Unidos, asesinato y destruir aviones.\",            \"translated_title\": \"Cargos Contra Castro\"        },        {            \"english_version\": \"Russia and China showed they were united on the world stage, but there are limits to their partnership.\",            \"english_title\": \"Russia and China Partnership\",            \"translated_version\": \"Rusia y China mostraron que est\u00e1n unidos en el mundo, pero hay l\u00edmites en su amistad.\",            \"translated_title\": \"Amistad de Rusia y China\"        },        {            \"english_version\": \"The spy scandal has brought back fears that Austria is still a center for Russian spying activities.\",            \"english_title\": \"Austria Spy Scandal\",            \"translated_version\": \"El esc\u00e1ndalo de esp\u00edas ha tra\u00eddo miedo de que Austria todav\u00eda sea un lugar para esp\u00edas rusos.\",            \"translated_title\": \"Esc\u00e1ndalo de Esp\u00edas en Austria\"        },        {            \"english_version\": \"France and Italy criticized a video showing Itamar Ben-Gvir mocking activists held at an Israeli port.\",            \"english_title\": \"Criticism of Video\",            \"translated_version\": \"Francia e Italia criticaron un video donde Itamar Ben-Gvir se burla de activistas en un puerto de Israel.\",            \"translated_title\": \"Cr\u00edtica al Video\"        },        {            \"english_version\": \"Flights were stopped and people were told to take cover after a suspected drone was seen near the Belarus border.\",            \"english_title\": \"Drone Near Belarus\",            \"translated_version\"