"{    \"translations\": [        {            \"english_version\": \"A British man is among three evacuees sent to the Netherlands after showing symptoms while on the MV Hondius.\",            \"english_title\": \"British Man Evacuated\",            \"translated_version\": \"Un hombre britanico esta entre tres personas enviadas a los Paises Bajos despues de mostrar sintomas en el MV Hondius.\",            \"translated_title\": \"Hombre Britanico Evacuado\"        },        {            \"english_version\": \"Israel says it targeted a senior Hezbollah figure in the capital, marking the first strike of its kind since mid-April.\",            \"english_title\": \"Israel Targets Hezbollah\",            \"translated_version\": \"Israel dice que ataco a un lider de Hezbollah en la capital, siendo el primer ataque asi desde mediados de abril.\",            \"translated_title\": \"Israel Ataca a Hezbollah\"        },        {            \"english_version\": \"Three women who allegedly supported IS were arrested after returning to Australia for the first time in years.\",            \"english_title\": \"Women Arrested in Australia\",            \"translated_version\": \"Tres mujeres que supuestamente apoyaron a IS fueron arrestadas despues de regresar a Australia por primera vez en anos.\",            \"translated_title\": \"Mujeres Arrestadas en Australia\"        },        {            \"english_version\": \"The energy giant's profits increased by nearly a quarter due to recent changes in oil prices.\",            \"english_title\": \"Energy Profits Rise\",            \"translated_version\": \"Las ganancias de la gran empresa de energia aumentaron casi un cuarto debido a cambios recientes en los precios del petroleo.\",            \"translated_title\": \"Aumentan Ganancias de Energia\"        },        {            \"english_version\": \"The media mogul started the modern 24-hour news culture by launching the Cable News Network in 1980.\",            \"english_title\": \"24-Hour News Culture\",            \"translated_version\": \"El magnate de los medios comenzo la cultura moderna de noticias 24 horas lanzando la Cable News Network en 1980.\",            \"translated_title\": \"Cultura de Noticias 24 Horas\"        }    ]}"