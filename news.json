"{    \"translations\": [        {            \"english_version\": \"A shipping boss says Donald Trump's plan to charge 20% on all cargo through the Strait of Hormuz won't work.\",            \"english_title\": \"Shipping Boss Criticizes Trump's Plan\",            \"translated_version\": \"Un jefe de env\u00edos dice que el plan de Donald Trump de cobrar 20% en toda la carga por el Estrecho de Ormuz no funcionar\u00e1.\",            \"translated_title\": \"Jefe de Env\u00edos Critica Plan de Trump\"        },        {            \"english_version\": \"The Iran-backed Houthis blame Saudi Arabia for an attack in Yemen's capital and say they targeted Abha airport in response.\",            \"english_title\": \"Houthis Blame Saudi Arabia\",            \"translated_version\": \"Los hut\u00edes apoyados por Ir\u00e1n culpan a Arabia Saudita por un ataque en la capital de Yemen y dicen que atacaron el aeropuerto de Abha en respuesta.\",            \"translated_title\": \"Hut\u00edes Culpan a Arabia Saudita\"        },        {            \"english_version\": \"Police hope images will help them find the body of Peter Falconio.\",            \"english_title\": \"Police Seek Help with Images\",            \"translated_version\": \"La polic\u00eda espera que las im\u00e1genes les ayuden a encontrar el cuerpo de Peter Falconio.\",            \"translated_title\": \"Polic\u00eda Busca Ayuda con Im\u00e1genes\"        },        {            \"english_version\": \"Hamish Tait is accused of abusing 136 children at five childcare facilities over 16 years.\",            \"english_title\": \"Hamish Tait Accused of Abuse\",            \"translated_version\": \"Hamish Tait es acusado de abusar de 136 ni\u00f1os en cinco guarder\u00edas durante 16 a\u00f1os.\",            \"translated_title\": \"Hamish Tait Acusado de Abuso\"        },        {            \"english_version\": \"The ban restricts exports of mercury and cyanide to Sudan, chemicals used in gold mining.\",            \"english_title\": \"Ban on Mercury and Cyanide Exports\",            \"translated_version\": \"La prohibici\u00f3n restringe las exportaciones de mercurio y cianuro a Sud\u00e1n, qu\u00edmicos usados en la miner\u00eda de oro.\",            \"translated_title\": \"Prohibici\u00f3n de Exportaciones de Mercurio y Cianuro\"        }    ]}"