"{    \"translations\": [        {            \"english_version\": \"President Trump says the US will destroy Iran's power plants if the important shipping channel does not open before his 48-hour deadline.\",            \"english_title\": \"Trump's Threat to Iran\",            \"translated_version\": \"El Presidente Trump dice que Estados Unidos destruir\u00e1 las plantas de energ\u00eda de Ir\u00e1n si el canal de env\u00edo importante no se abre antes de su plazo de 48 horas.\",            \"translated_title\": \"Amenaza de Trump a Ir\u00e1n\"        },        {            \"english_version\": \"Israel is looking into how ballistic missiles got through the country's advanced air defenses.\",            \"english_title\": \"Israel's Missile Investigation\",            \"translated_version\": \"Israel est\u00e1 investigando c\u00f3mo misiles bal\u00edsticos pasaron por las defensas a\u00e9reas avanzadas del pa\u00eds.\",            \"translated_title\": \"Investigaci\u00f3n de Misiles de Israel\"        },        {            \"english_version\": \"The deaths were reported in four southeastern Ukrainian regions in the past 24 hours.\",            \"english_title\": \"Deaths in Ukraine\",            \"translated_version\": \"Las muertes fueron reportadas en cuatro regiones del sureste de Ucrania en las \u00faltimas 24 horas.\",            \"translated_title\": \"Muertes en Ucrania\"        },        {            \"english_version\": \"Another complete failure of its power grid highlights Cuba's difficulties under a US-imposed fuel blockade.\",            \"english_title\": \"Cuba's Power Grid Failure\",            \"translated_version\": \"Otro fallo completo de su red el\u00e9ctrica muestra las dificultades de Cuba bajo un bloqueo de combustible impuesto por Estados Unidos.\",            \"translated_title\": \"Fallo de Red El\u00e9ctrica en Cuba\"        },        {            \"english_version\": \"The capital could move to the right after 25 years under the Socialists if Rachida Dati beats Emmanuel Gr\u00e9goire.\",            \"english_title\": \"Possible Political Shift in Capital\",            \"translated_version\": \"La capital podr\u00eda moverse a la derecha despu\u00e9s de 25 a\u00f1os bajo los Socialistas si Rachida Dati vence a Emmanuel Gr\u00e9goire.\",            \"translated_title\": \"Cambio Pol\u00edtico Posible en la Capital\"        }    ]}"