"{    \"translations\": [        {            \"english_version\": \"The US president wants China and Taiwan to reduce tensions over Taiwan. There were many planned ceremonies but no trade deals after the two-day visit.\",            \"english_title\": \"US President on China-Taiwan Tensions\",            \"translated_version\": \"El presidente de Estados Unidos quiere que China y Taiw\u00e1n reduzcan las tensiones sobre Taiw\u00e1n. Hubo muchas ceremonias planeadas pero no acuerdos comerciales despu\u00e9s de la visita de dos d\u00edas.\",            \"translated_title\": \"Presidente de EE.UU. sobre tensiones China-Taiw\u00e1n\"        },        {            \"english_version\": \"A New York jury is considering the case against a 74-year-old former film mogul for the third time.\",            \"english_title\": \"Jury Considers Case Against Former Film Mogul\",            \"translated_version\": \"Un jurado de Nueva York est\u00e1 considerando el caso contra un ex magnate del cine de 74 a\u00f1os por tercera vez.\",            \"translated_title\": \"Jurado considera caso contra ex magnate del cine\"        },        {            \"english_version\": \"President Trump announced a truce last month, but Israel and Hezbollah have continued to exchange fire since then.\",            \"english_title\": \"Truce Announced but Fighting Continues\",            \"translated_version\": \"El presidente Trump anunci\u00f3 una tregua el mes pasado, pero Israel y Hezbollah han continuado intercambiando disparos desde entonces.\",            \"translated_title\": \"Tregua anunciada pero sigue la lucha\"        },        {            \"english_version\": \"Israel's prime minister has ordered legal action over an article that claimed Israeli security officials raped Palestinian detainees.\",            \"english_title\": \"Legal Action Over Article on Detainee Abuse\",            \"translated_version\": \"El primer ministro de Israel ha ordenado acciones legales sobre un art\u00edculo que dec\u00eda que oficiales de seguridad israel\u00edes violaron a detenidos palestinos.\",            \"translated_title\": \"Acci\u00f3n legal por art\u00edculo sobre abuso a detenidos\"        },        {            \"english_version\": \"The US government claims that Elias Rodriguez shot and killed a young Jewish couple at an event in Washington last May.\",            \"english_title\": \"US Government Accuses Elias Rodriguez\",            \"translated_version\": \"El gobierno de Estados Unidos dice que Elias Rodriguez dispar\u00f3 y mat\u00f3 a una joven pareja jud\u00eda en un evento en Washington el pasado mayo.\",            \"translated_title\": \"Gobierno de EE.UU. acusa a Elias Rodriguez\"        }    ]}"