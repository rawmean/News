"{    \"translations\": [        {            \"english_version\": \"Pakistan's defense minister has declared open war after the Afghan Taliban said it launched strikes on Pakistan. This happened on Thursday night.\",            \"english_title\": \"Pakistan Declares War\",            \"translated_version\": \"El ministro de defensa de Pakist\u00e1n ha declarado guerra abierta despu\u00e9s de que los talibanes afganos dijeron que lanzaron ataques en Pakist\u00e1n. Esto pas\u00f3 el jueves por la noche.\",            \"translated_title\": \"Pakist\u00e1n Declara Guerra\"        },        {            \"english_version\": \"Netflix has decided to step back from a bidding war, which allows Paramount to win the takeover battle.\",            \"english_title\": \"Netflix Steps Back\",            \"translated_version\": \"Netflix ha decidido retirarse de una guerra de ofertas, lo que permite a Paramount ganar la batalla de adquisici\u00f3n.\",            \"translated_title\": \"Netflix Se Retira\"        },        {            \"english_version\": \"Sweden's defense minister says there is likely a strong link between a drone and a Russian naval vessel in the area.\",            \"english_title\": \"Sweden's Drone Link\",            \"translated_version\": \"El ministro de defensa de Suecia dice que probablemente hay un fuerte v\u00ednculo entre un dron y un barco naval ruso en el \u00e1rea.\",            \"translated_title\": \"V\u00ednculo de Dron en Suecia\"        },        {            \"english_version\": \"Cuba has accused people on board a vessel of planning an infiltration with terrorist aims and firing first.\",            \"english_title\": \"Cuba Accuses Vessel\",            \"translated_version\": \"Cuba ha acusado a personas a bordo de un barco de planear una infiltraci\u00f3n con objetivos terroristas y disparar primero.\",            \"translated_title\": \"Cuba Acusa Barco\"        },        {            \"english_version\": \"A total of 1,000 Kenyans have reportedly been recruited to fight for Russia in its war against Ukraine.\",            \"english_title\": \"Kenyans Recruited for Russia\",            \"translated_version\": \"Un total de 1,000 kenianos han sido reclutados para luchar por Rusia en su guerra contra Ucrania.\",            \"translated_title\": \"Kenianos Reclutados para Rusia\"        }    ]}"