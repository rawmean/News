"{    \"translations\": [        {            \"english_version\": \"A woman has been awarded $6 million in a verdict that could affect many other cases in the US.\",            \"english_title\": \"Woman Wins $6 Million\",            \"translated_version\": \"Una mujer gan\u00f3 $6 millones en un juicio que puede afectar otros casos en Estados Unidos.\",            \"translated_title\": \"Mujer Gana $6 Millones\"        },        {            \"english_version\": \"The White House Press Secretary said talks between the US and Iran are ongoing but did not give more details.\",            \"english_title\": \"US-Iran Talks Continue\",            \"translated_version\": \"El Secretario de Prensa de la Casa Blanca dijo que las conversaciones entre Estados Unidos e Ir\u00e1n siguen, pero no dio m\u00e1s detalles.\",            \"translated_title\": \"Conversaciones EEUU-Ir\u00e1n Siguen\"        },        {            \"english_version\": \"The President says the country will buy one million barrels of oil to add to the current stock.\",            \"english_title\": \"Country to Buy Oil\",            \"translated_version\": \"El Presidente dice que el pa\u00eds comprar\u00e1 un mill\u00f3n de barriles de petr\u00f3leo para a\u00f1adir al stock actual.\",            \"translated_title\": \"Pa\u00eds Comprar\u00e1 Petr\u00f3leo\"        },        {            \"english_version\": \"The party, which has been in power since 2019, got the most votes but faces difficult talks to form a new government.\",            \"english_title\": \"Party Wins Most Votes\",            \"translated_version\": \"El partido, que est\u00e1 en el poder desde 2019, obtuvo m\u00e1s votos pero enfrenta conversaciones dif\u00edciles para formar un nuevo gobierno.\",            \"translated_title\": \"Partido Gana M\u00e1s Votos\"        },        {            \"english_version\": \"Some of the 32 bodies, including 25 children, are believed to have come from local hospitals and mortuaries.\",            \"english_title\": \"Bodies Found\",            \"translated_version\": \"Se cree que algunos de los 32 cuerpos, incluyendo 25 ni\u00f1os, vinieron de hospitales y morgues locales.\",            \"translated_title\": \"Cuerpos Encontrados\"        }    ]}"