"{    \"translations\": [        {            \"english_version\": \"The bill would allow assisted dying for terminally ill adults who meet strict criteria.\",            \"english_title\": \"Assisted Dying Bill\",            \"translated_version\": \"La ley permitiria morir con ayuda a adultos muy enfermos que cumplen criterios estrictos.\",            \"translated_title\": \"Ley de Morir con Ayuda\"        },        {            \"english_version\": \"Argentina face the prospect of disciplinary action from Fifa after their players celebrate the World Cup semi-final win against England with a banner in support of their country's claims to the Falkland Islands.\",            \"english_title\": \"Argentina Faces Fifa Action\",            \"translated_version\": \"Argentina puede tener problemas con Fifa porque sus jugadores celebraron la victoria en la semifinal del Mundial contra Inglaterra con un cartel apoyando las Islas Malvinas.\",            \"translated_title\": \"Argentina y Problemas con Fifa\"        },        {            \"english_version\": \"A large section of the giant Morandi motorway bridge crumbled and collapsed on to the railway tracks below.\",            \"english_title\": \"Bridge Collapse\",            \"translated_version\": \"Una gran parte del puente gigante Morandi se derrumbo y cayo sobre las vias del tren abajo.\",            \"translated_title\": \"Colapso de Puente\"        },        {            \"english_version\": \"Civilian casualties are reported in a number of Ukrainian regions, while Kyiv hits 20 Russian vessels in the Black Sea.\",            \"english_title\": \"Casualties in Ukraine\",            \"translated_version\": \"Se reportan heridos civiles en varias regiones de Ucrania, mientras Kyiv ataca 20 barcos rusos en el Mar Negro.\",            \"translated_title\": \"Heridos en Ucrania\"        },        {            \"english_version\": \"Officials say they are suspected of selling 'seditious' books which incited 'hatred' against authorities.\",            \"english_title\": \"Seditious Books Sold\",            \"translated_version\": \"Los oficiales dicen que sospechan que vendieron libros 'sediciosos' que incitan 'odio' contra las autoridades.\",            \"translated_title\": \"Venta de Libros Sediciosos\"        }    ]}"