"{    \"translations\": [        {            \"english_version\": \"Kenneth Law admitted charges related to Canadian victims. Families want him charged in the UK for 79 deaths in Britain.\",            \"english_title\": \"Kenneth Law Charges\",            \"translated_version\": \"Kenneth Law admiti\u00f3 cargos relacionados con v\u00edctimas en Canad\u00e1. Las familias quieren que lo acusen en el Reino Unido por 79 muertes en Gran Breta\u00f1a.\",            \"translated_title\": \"Cargos de Kenneth Law\"        },        {            \"english_version\": \"Romania says a Russian drone was likely hit over Ukraine by air defenses, changing its path.\",            \"english_title\": \"Russian Drone Incident\",            \"translated_version\": \"Rumania dice que un dron ruso fue probablemente golpeado sobre Ucrania por defensas a\u00e9reas, cambiando su camino.\",            \"translated_title\": \"Incidente de Dron Ruso\"        },        {            \"english_version\": \"Israel rejects claims in a new report by the UN secretary general's office.\",            \"english_title\": \"Israel Rejects UN Report\",            \"translated_version\": \"Israel rechaza afirmaciones en un nuevo informe de la oficina del secretario general de la ONU.\",            \"translated_title\": \"Israel Rechaza Informe de la ONU\"        },        {            \"english_version\": \"Corruption investigations involving colleagues and relatives have put Spain's leader in a tough position.\",            \"english_title\": \"Spain's Leader in Trouble\",            \"translated_version\": \"Investigaciones de corrupci\u00f3n con colegas y familiares han puesto al l\u00edder de Espa\u00f1a en una posici\u00f3n dif\u00edcil.\",            \"translated_title\": \"L\u00edder de Espa\u00f1a en Problemas\"        },        {            \"english_version\": \"The US president met with advisers after officials confirmed a deal framework between the US and Iran.\",            \"english_title\":