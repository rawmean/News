"{    \"translations\": [        {            \"english_version\": \"A suspect approached a checkpoint near a building and opened fire, injuring a bystander.\",            \"english_title\": \"Shooting Incident\",            \"translated_version\": \"Un sospechoso se acerc\u00f3 a un control cerca de un edificio y dispar\u00f3, hiriendo a una persona.\",            \"translated_title\": \"Incidente de disparos\"        },        {            \"english_version\": \"Tehran is making progress on talks but says nuclear weapons are not part of the initial framework.\",            \"english_title\": \"Tehran Talks\",            \"translated_version\": \"Teher\u00e1n est\u00e1 avanzando en las conversaciones pero dice que las armas nucleares no son parte del plan inicial.\",            \"translated_title\": \"Conversaciones de Teher\u00e1n\"        },        {            \"english_version\": \"Eighteen people were killed and 42 others injured in a strike on a town in Russian-occupied eastern Ukraine.\",            \"english_title\": \"Strike in Ukraine\",            \"translated_version\": \"Dieciocho personas murieron y 42 m\u00e1s resultaron heridas en un ataque a un pueblo en el este de Ucrania ocupado por Rusia.\",            \"translated_title\": \"Ataque en Ucrania\"        },        {            \"english_version\": \"A blast in Shanxi province is the worst mining disaster in China in 16 years.\",            \"english_title\": \"Mining Disaster\",            \"translated_version\": \"Una explosi\u00f3n en la provincia de Shanxi es el peor desastre minero en China en 16 a\u00f1os.\",            \"translated_title\": \"Desastre minero\"        },        {            \"english_version\": \"Ukraine says it hit Russia's elite Rubicon drone military unit in a Moscow-occupied region.\",            \"english_title\": \"Drone Unit Hit\",            \"translated_version\": \"Ucrania dice que golpe\u00f3 la unidad militar de drones Rubicon de \u00e9lite de Rusia en una regi\u00f3n ocupada por Mosc\u00fa.\",            \"translated_title\": \"Unidad de drones golpeada\"        }    ]}"