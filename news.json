"{    \"translations\": [        {            \"english_version\": \"Tehran has warned that it will strike back against energy infrastructure linked to the US in the Middle East if its power plants are attacked.\",            \"english_title\": \"Tehran's Warning\",            \"translated_version\": \"Tehran ha dicho que atacar\u00e1 cosas de energ\u00eda de Estados Unidos en el Medio Oriente si atacan sus plantas de energ\u00eda.\",            \"translated_title\": \"Advertencia de Tehran\"        },        {            \"english_version\": \"Israel is looking into how ballistic missiles managed to bypass the country's advanced air defense systems.\",            \"english_title\": \"Israel's Missile Investigation\",            \"translated_version\": \"Israel est\u00e1 investigando c\u00f3mo misiles pasaron sus sistemas avanzados de defensa a\u00e9rea.\",            \"translated_title\": \"Investigaci\u00f3n de Misiles de Israel\"        },        {            \"english_version\": \"A former FBI director, Mueller, led the well-known investigation into claims of Russian interference in the 2016 US election.\",            \"english_title\": \"Mueller's Investigation\",            \"translated_version\": \"Un ex director del FBI, Mueller, dirigi\u00f3 la famosa investigaci\u00f3n sobre las acusaciones de interferencia rusa en las elecciones de Estados Unidos de 2016.\",            \"translated_title\": \"Investigaci\u00f3n de Mueller\"        },        {            \"english_version\": \"The capital city might lean towards the right after 25 years under the Socialists if Rachida Dati wins against Emmanuel Gr\u00e9goire.\",            \"english_title\": \"Possible Political Shift\",            \"translated_version\": \"La ciudad capital podr\u00eda ir hacia la derecha despu\u00e9s de 25 a\u00f1os con los Socialistas si Rachida Dati gana contra Emmanuel Gr\u00e9goire.\",            \"translated_title\": \"Cambio Pol\u00edtico Posible\"        },        {            \"english_version\": \"Another complete failure of its power grid highlights Cuba's struggles under a US-imposed fuel blockade.\",            \"english_title\": \"Cuba's Power Struggles\",            \"translated_version\": \"Otro fallo completo de su red el\u00e9ctrica muestra las dificultades de Cuba bajo un bloqueo de combustible impuesto por Estados Unidos.\",            \"translated_title\": \"Problemas de Energ\u00eda en Cuba\"        }    ]}"