"{    \"translations\": [        {            \"english_version\": \"Steve Rosenberg talks about how Russia's war is affecting the economy and how people are dealing with it.\",            \"english_title\": \"Russia's War and Economy\",            \"translated_version\": \"Steve Rosenberg habla sobre como la guerra de Rusia afecta la economia y como la gente lo maneja.\",            \"translated_title\": \"Guerra de Rusia y Economia\"        },        {            \"english_version\": \"Ukraine's president spoke with the BBC's Jeremy Bowen in Kyiv just before the four-year anniversary of the war.\",            \"english_title\": \"Ukraine President Interview\",            \"translated_version\": \"El presidente de Ucrania hablo con Jeremy Bowen de la BBC en Kyiv justo antes del aniversario de cuatro anos de la guerra.\",            \"translated_title\": \"Entrevista Presidente de Ucrania\"        },        {            \"english_version\": \"The death of the leader of the Jalisco cartel in Mexico has led to violence in many states.\",            \"english_title\": \"Jalisco Cartel Leader's Death\",            \"translated_version\": \"La muerte del lider del cartel de Jalisco en Mexico ha causado violencia en muchos estados.\",            \"translated_title\": \"Muerte del Lider del Cartel de Jalisco\"        },        {            \"english_version\": \"Pakistan says it carried out strikes in response to recent suicide bombings in the country.\",            \"english_title\": \"Pakistan Strikes Back\",            \"translated_version\": \"Pakistan dice que hizo ataques en respuesta a recientes bombardeos suicidas en el pais.\",            \"translated_title\": \"Pakistan Responde\"        },        {            \"english_version\": \"Twenty-five people were hurt by explosions overnight, which officials are calling a terror attack.\",            \"english_title\": \"Explosions Hurt Many\",            \"translated_version\": \"Veinticinco personas fueron heridas por explosiones durante la noche, que los oficiales llaman un ataque terrorista.\",            \"translated_title\": \"Explosiones Hieren a Muchos\"        }    ]}"