"{    \"translations\": [        {            \"english_version\": \"Logistics hubs belonging to Wildberries in the Krasnodar and Stavropol regions were attacked overnight.\",            \"english_title\": \"Wildberries Hubs Attacked\",            \"translated_version\": \"Centros de log\u00edstica de Wildberries en las regiones de Krasnodar y Stavropol fueron atacados durante la noche.\",            \"translated_title\": \"Centros de Wildberries Atacados\"        },        {            \"english_version\": \"Oleksandr Syrskyi was removed after people were upset about the removal of popular Defence Minister Mykhailo Fedorov.\",            \"english_title\": \"Oleksandr Syrskyi Removed\",            \"translated_version\": \"Oleksandr Syrskyi fue removido despu\u00e9s de que la gente se molest\u00f3 por la salida del popular Ministro de Defensa Mykhailo Fedorov.\",            \"translated_title\": \"Oleksandr Syrskyi Removido\"        },        {            \"english_version\": \"The Tokyo Metropolitan Government wants workers to wear casual clothes like t-shirts, trainers, and shorts instead of suits and ties.\",            \"english_title\": \"Tokyo Dress Code Change\",            \"translated_version\": \"El Gobierno Metropolitano de Tokio quiere que los trabajadores usen ropa casual como camisetas, zapatillas y pantalones cortos en lugar de trajes y corbatas.\",            \"translated_title\": \"Cambio de Ropa en Tokio\"        },        {            \"english_version\": \"The opening of a 17th-Century former inn, where the Nazi dictator was born, follows years of debate about what to do with it.\",            \"english_title\": \"Opening of Historic Inn\",            \"translated_version\": \"La apertura de una antigua posada del siglo 17, donde naci\u00f3 el dictador nazi, sigue a\u00f1os de debate sobre qu\u00e9 hacer con ella.\",            \"translated_title\": \"Apertura de Posada Hist\u00f3rica\"        },        {            \"english_version\": \"The US president threatened to target a key Iranian nuclear site before the 11th night of attacks.\",            \"english_title\": \"US President Threatens Iran\",            \"translated_version\": \"El presidente de EE.UU. amenaz\u00f3 con atacar un sitio nuclear clave de Ir\u00e1n antes de la und\u00e9cima noche de ataques.\",            \"translated_title\": \"Presidente de EE.UU. Amenaza a Ir\u00e1n\"        }    ]}"