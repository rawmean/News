"{    \"translations\": [        {            \"english_version\": \"Tehran is making progress in talks, but the issue of nuclear weapons is not part of the initial framework they are working on.\",            \"english_title\": \"Tehran Talks Progress\",            \"translated_version\": \"Tehran est\u00e1 avanzando en las conversaciones, pero el tema de las armas nucleares no es parte del plan inicial en el que est\u00e1n trabajando.\",            \"translated_title\": \"Progreso en Conversaciones de Tehran\"        },        {            \"english_version\": \"A blast in Shanxi province is the worst mining disaster in China in 16 years.\",            \"english_title\": \"Shanxi Mining Disaster\",            \"translated_version\": \"Una explosi\u00f3n en la provincia de Shanxi es el peor desastre minero en China en 16 a\u00f1os.\",            \"translated_title\": \"Desastre Minero en Shanxi\"        },        {            \"english_version\": \"Four-time Formula 1 world champion Alain Prost was injured when a masked gang raided his home near Geneva, according to Swiss media.\",            \"english_title\": \"Alain Prost Injured\",            \"translated_version\": \"El cuatro veces campe\u00f3n mundial de F\u00f3rmula 1, Alain Prost, fue herido cuando una banda enmascarada asalt\u00f3 su casa cerca de Ginebra, seg\u00fan medios suizos.\",            \"translated_title\": \"Alain Prost Herido\"        },        {            \"english_version\": \"Ukraine claims it hit Russia's elite Rubicon drone military unit in a region occupied by Moscow.\",            \"english_title\": \"Ukraine Hits Russian Unit\",            \"translated_version\": \"Ucrania dice que golpe\u00f3 la unidad militar de drones Rubicon de Rusia en una regi\u00f3n ocupada por Mosc\u00fa.\",            \"translated_title\": \"Ucrania Golpea Unidad Rusa\"        },        {            \"english_version\": \"The largest and most powerful rocket in history launched successfully after its first attempt was postponed.\",            \"english_title\": \"Historic Rocket Launch\",            \"translated_version\": \"El cohete m\u00e1s grande y poderoso de la historia se lanz\u00f3 con \u00e9xito despu\u00e9s de que su primer intento fue pospuesto.\",            \"translated_title\": \"Lanzamiento Hist\u00f3rico de Cohete\"        }    ]}"