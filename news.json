"{    \"translations\": [        {            \"english_version\": \"Iran has attacked US allies in the region. Kuwait reported that a power and water plant was hit.\",            \"english_title\": \"Iran Attacks US Allies\",            \"translated_version\": \"Ir\u00e1n atac\u00f3 a aliados de EE.UU. en la regi\u00f3n. Kuwait dijo que una planta de energ\u00eda y agua fue golpeada.\",            \"translated_title\": \"Ir\u00e1n Ataca Aliados de EE.UU.\"        },        {            \"english_version\": \"Canadian leader Mark Carney says the US and Canada both need to fight climate change. Experts say climate change is making wildfires worse.\",            \"english_title\": \"Canada and US on Climate Change\",            \"translated_version\": \"El l\u00edder canadiense Mark Carney dice que EE.UU. y Canad\u00e1 necesitan luchar contra el cambio clim\u00e1tico. Expertos dicen que el cambio clim\u00e1tico hace que los incendios sean peores.\",            \"translated_title\": \"Canad\u00e1 y EE.UU. en Cambio Clim\u00e1tico\"        },        {            \"english_version\": \"Protests started in Ukraine after Mykhailo Fedorov was removed. Soldiers are also criticizing this decision.\",            \"english_title\": \"Protests in Ukraine\",            \"translated_version\": \"Protestas comenzaron en Ucrania despu\u00e9s de que Mykhailo Fedorov fue removido. Soldados tambi\u00e9n critican esta decisi\u00f3n.\",            \"translated_title\": \"Protestas en Ucrania\"        },        {            \"english_version\": \"India's first space-tech unicorn, Skyroot Aerospace, launched Vikram-1 successfully on Saturday.\",            \"english_title\": \"India's Space-Tech Success\",            \"translated_version\": \"El primer unicornio de tecnolog\u00eda espacial de India, Skyroot Aerospace, lanz\u00f3 Vikram-1 con \u00e9xito el s\u00e1bado.\",            \"translated_title\": \"\u00c9xito Espacial de India\"        },        {            \"english_version\": \"The US Tsunami Warning Center recorded waves 0.3m high in Puerto Madero and Chiapas, Mexico, after an earthquake.\",            \"english_title\": \"Tsunami Waves in Mexico\",            \"translated_version\": \"El Centro de Alerta de Tsunamis de EE.UU. registr\u00f3 olas de 0.3m de altura en Puerto Madero y Chiapas, M\u00e9xico, despu\u00e9s de un terremoto.\",            \"translated_title\": \"Olas de Tsunami en M\u00e9xico\"        }    ]}"