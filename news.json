"{    \"translations\": [        {            \"english_version\": \"Thousands of officers tried to control the unrest as fans celebrated PSG's victory over Arsenal. Some fans were firing flares.\",            \"english_title\": \"PSG Victory Unrest\",            \"translated_version\": \"Miles de polic\u00edas trataron de controlar el desorden mientras los fans celebraban la victoria de PSG sobre Arsenal. Algunos fans lanzaban bengalas.\",            \"translated_title\": \"Desorden por victoria de PSG\"        },        {            \"english_version\": \"The technology developed under the Aukus military pact is meant to protect undersea cables and improve naval defense.\",            \"english_title\": \"Aukus Pact Technology\",            \"translated_version\": \"La tecnolog\u00eda desarrollada bajo el pacto militar Aukus es para proteger cables submarinos y mejorar la defensa naval.\",            \"translated_title\": \"Tecnolog\u00eda del pacto Aukus\"        },        {            \"english_version\": \"The film editor and ex-wife of director George Lucas was a key creative force behind the original space trilogy.\",            \"english_title\": \"Creative Force in Space Trilogy\",            \"translated_version\": \"La editora de pel\u00edculas y exesposa del director George Lucas fue una fuerza creativa importante detr\u00e1s de la trilog\u00eda espacial original.\",            \"translated_title\": \"Fuerza creativa en trilog\u00eda espacial\"        },        {            \"english_version\": \"Ecuadorian leader Daniel Noboa offers to cancel tariffs after talking to a right-wing presidential candidate before Sunday's vote.\",            \"english_title\": \"Ecuador Tariff Offer\",            \"translated_version\": \"El l\u00edder ecuatoriano Daniel Noboa ofrece cancelar tarifas despu\u00e9s de hablar con un candidato presidencial de derecha antes de la votaci\u00f3n del domingo.\",            \"translated_title\": \"Oferta de tarifas en Ecuador\"     