"{    \"translations\": [        {            \"english_version\": \"Shipping company Maersk says one of its US-flagged commercial ships has safely left the Strait of Hormuz with help from the US military.\",            \"english_title\": \"Maersk Ship Safe\",            \"translated_version\": \"La empresa de barcos Maersk dice que uno de sus barcos comerciales con bandera de Estados Unidos ha salido seguro del Estrecho de Hormuz con ayuda del ej\u00e9rcito de Estados Unidos.\",            \"translated_title\": \"Barco de Maersk Seguro\"        },        {            \"english_version\": \"A 33-year-old German citizen was arrested after an incident, according to authorities.\",            \"english_title\": \"German Citizen Arrested\",            \"translated_version\": \"Un ciudadano alem\u00e1n de 33 a\u00f1os fue arrestado despu\u00e9s de un incidente, seg\u00fan las autoridades.\",            \"translated_title\": \"Ciudadano Alem\u00e1n Arrestado\"        },        {            \"english_version\": \"The operator of the MV Hondius ship says a Dutch couple and a German person have died.\",            \"english_title\": \"Deaths on MV Hondius\",            \"translated_version\": \"El operador del barco MV Hondius dice que una pareja holandesa y una persona alemana han muerto.\",            \"translated_title\": \"Muertes en MV Hondius\"        },        {            \"english_version\": \"Russia has announced a ceasefire for an event and warned of a big attack on central Kyiv if it is disturbed.\",            \"english_title\": \"Russia Ceasefire Warning\",            \"translated_version\": \"Rusia ha anunciado un alto el fuego para un evento y ha advertido de un gran ataque en el centro de Kyiv si se interrumpe.\",            \"translated_title\": \"Advertencia de Alto el Fuego de Rusia\"        },        {            \"english_version\": \"The Civil Guard found between 30,000 and 45,000 kilograms of drugs on a ship going to Libya.\",            \"english_title\": \"Drugs Found on Ship\",            \"translated_version\": \"La Guardia Civil encontr\u00f3 entre 30,000 y 45,000 kilogramos de drogas en un barco que iba a Libia.\",            \"translated_title\": \"Drogas Encontradas en Barco\"        }    ]}"