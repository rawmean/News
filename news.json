"{    \"translations\": [        {            \"english_version\": \"Israel and Hezbollah are still fighting even though they agreed to stop last month.\",            \"english_title\": \"Israel and Hezbollah Conflict\",            \"translated_version\": \"Israel y Hezbollah siguen peleando aunque dijeron que parar\u00edan el mes pasado.\",            \"translated_title\": \"Conflicto Israel y Hezbollah\"        },        {            \"english_version\": \"The Russian leader thinks there might be a chance to talk about peace in Ukraine, but he criticizes the West for supporting President Zelensky.\",            \"english_title\": \"Russian Leader on Ukraine Peace\",            \"translated_version\": \"El l\u00edder ruso cree que hay una oportunidad de hablar de paz en Ucrania, pero critica a Occidente por apoyar al Presidente Zelensky.\",            \"translated_title\": \"L\u00edder Ruso sobre Paz en Ucrania\"        },        {            \"english_version\": \"P\u00e9ter Magyar led his Tisza party to a big win, ending Viktor Orb\u00e1n's 16 years in power.\",            \"english_title\": \"P\u00e9ter Magyar's Victory\",            \"translated_version\": \"P\u00e9ter Magyar llev\u00f3 a su partido Tisza a una gran victoria, terminando con los 16 a\u00f1os de poder de Viktor Orb\u00e1n.\",            \"translated_title\": \"Victoria de P\u00e9ter Magyar\"        },        {            \"english_version\": \"The Iranian Football Federation has given Fifa 10 conditions for playing in the World Cup in the US, Mexico, and Canada.\",            \"english_title\": \"Iran's World Cup Conditions\",            \"translated_version\": \"La Federaci\u00f3n de F\u00fatbol de Ir\u00e1n ha dado a Fifa 10 condiciones para jugar en el Mundial en EE.UU., M\u00e9xico y Canad\u00e1.\",            \"translated_title\": \"Condiciones de Ir\u00e1n para el Mundial\"        },        {            \"english_version\": \"A hacking group broke into the academic software Canvas, which is used by many schools and universities around the world.\",            \"english_title\": \"Canvas Hacking Incident\",            \"translated_version\": \"Un grupo de hackers entr\u00f3 en el software acad\u00e9mico Canvas, que es usado por muchas escuelas y universidades en el mundo.\",            \"translated_title\": \"Incidente de Hackeo en Canvas\"        }    ]}"