"{    \"translations\": [        {            \"english_version\": \"President Donald Trump says he asked Fifa to look again at the one-match ban given to United States striker Folarin Balogun during the World Cup.\",            \"english_title\": \"Trump Asks Fifa to Review Ban\",            \"translated_version\": \"El presidente Donald Trump dice que pidi\u00f3 a Fifa que revise la suspensi\u00f3n de un partido dada al delantero de Estados Unidos Folarin Balogun durante la Copa del Mundo.\",            \"translated_title\": \"Trump pide a Fifa revisar suspensi\u00f3n\"        },        {            \"english_version\": \"President Zelensky reports that a large Russian attack on Kyiv involved 68 missiles and 351 strike drones.\",            \"english_title\": \"Russian Attack on Kyiv\",            \"translated_version\": \"El presidente Zelensky informa que un gran ataque ruso en Kyiv involucr\u00f3 68 misiles y 351 drones de ataque.\",            \"translated_title\": \"Ataque ruso en Kyiv\"        },        {            \"english_version\": \"Tour de France organizers have stopped spectators from attending stage three because of a wildfire in the Pyr\u00e9n\u00e9es-Orientales area.\",            \"english_title\": \"Tour de France Stage Closed\",            \"translated_version\": \"Los organizadores del Tour de Francia han detenido a los espectadores de asistir a la etapa tres por un incendio en el \u00e1rea de Pyr\u00e9n\u00e9es-Orientales.\",            \"translated_title\": \"Etapa del Tour de Francia cerrada\"        },        {            \"english_version\": \"Interpol reports that most of the 2,070 victims or potential victims they found were women being trafficked for sex.\",            \"english_title\": \"Interpol Finds Trafficking Victims\",            \"translated_version\": \"Interpol informa que la mayor\u00eda de las 2,070 v\u00edctimas o posibles v\u00edctimas que encontraron eran mujeres siendo traficadas para sexo.\",            \"translated_title\": \"Interpol encuentra v\u00edctimas de tr\u00e1fico\"        },        {            \"english_version\": \"Two former Syrian officials are on trial in Vienna, Austria, for crimes against people who opposed former Syrian leader Bashar al-Assad.\",            \"english_title\": \"Syrian Officials on Trial\",            \"translated_version\": \"Dos exfuncionarios sirios est\u00e1n en juicio en Viena, Austria, por cr\u00edmenes contra personas que se opusieron al exl\u00edder sirio Bashar al-Assad.\",            \"translated_title\": \"Funcionarios sirios en juicio\"        }    ]}"