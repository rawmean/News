"{    \"translations\": [        {            \"english_version\": \"The US president has told other countries that the USA will not help them with jet fuel anymore because they did not help the USA before.\",            \"english_title\": \"US Stops Jet Fuel Help\",            \"translated_version\": \"El presidente de Estados Unidos dijo a otros paises que Estados Unidos no les ayudara mas con combustible para aviones porque no ayudaron a Estados Unidos antes.\",            \"translated_title\": \"Estados Unidos deja de ayudar con combustible\"        },        {            \"english_version\": \"An 11-year-old child was killed in an air strike while at a checkpoint in Tehran.\",            \"english_title\": \"Child Killed in Air Strike\",            \"translated_version\": \"Un nino de 11 anos murio en un ataque aereo mientras estaba en un control en Teheran.\",            \"translated_title\": \"Nino muere en ataque aereo\"        },        {            \"english_version\": \"A Russian oil tanker has arrived in Cuba, giving temporary help after months of not having enough oil.\",            \"english_title\": \"Russian Oil Tanker in Cuba\",            \"translated_version\": \"Un barco petrolero ruso llego a Cuba, dando ayuda temporal despues de meses sin suficiente petroleo.\",            \"translated_title\": \"Barco ruso en Cuba\"        },        {            \"english_version\": \"China has banned 'bone ash apartments' where people keep cremated remains instead of using cemeteries.\",            \"english_title\": \"China Bans Bone Ash Apartments\",            \"translated_version\": \"China prohibio los apartamentos de cenizas donde la gente guarda restos cremados en lugar de usar cementerios.\",            \"translated_title\": \"China prohibe apartamentos de cenizas\"        },        {            \"english_version\": \"The Supreme Court decided that a man did more than just harass a woman by kissing her hand because there was a clear sexual intention.\",            \"english_title\": \"Court Rules on Harassment\",            \"translated_version\": \"La Corte Suprema decidio que un hombre hizo mas que solo molestar a una mujer al besar su mano porque habia una clara intencion sexual.\",            \"translated_title\": \"Corte decide sobre acoso\"        }    ]}"