"{    \"translations\": [        {            \"english_version\": \"Iranian forces said they closed the Strait and attacked US allies and bases in the area.\",            \"english_title\": \"Iran Closes Strait\",            \"translated_version\": \"Las fuerzas de Ir\u00e1n dijeron que cerraron el Estrecho y atacaron a aliados y bases de Estados Unidos en el \u00e1rea.\",            \"translated_title\": \"Ir\u00e1n cierra Estrecho\"        },        {            \"english_version\": \"Donald Trump honored a 71-year-old South Carolina senator, calling him a true American patriot who will be greatly missed.\",            \"english_title\": \"Trump Honors Senator\",            \"translated_version\": \"Donald Trump honr\u00f3 a un senador de Carolina del Sur de 71 a\u00f1os, llam\u00e1ndolo un verdadero patriota americano que ser\u00e1 muy extra\u00f1ado.\",            \"translated_title\": \"Trump honra senador\"        },        {            \"english_version\": \"A 67 million-year-old Tyrannosaurus rex is going to be sold in New York, and it might be worth $30 million.\",            \"english_title\": \"Tyrannosaurus Rex Sale\",            \"translated_version\": \"Un Tyrannosaurus rex de 67 millones de a\u00f1os va a ser vendido en Nueva York, y podr\u00eda valer 30 millones de d\u00f3lares.\",            \"translated_title\": \"Venta de Tiranosaurio Rex\"        },        {            \"english_version\": \"Schools, work, and outdoor activities stopped in Zhejiang province, and many transport services were canceled.\",            \"english_title\": \"Zhejiang Stops Activities\",            \"translated_version\": \"Escuelas, trabajo y actividades al aire libre se detuvieron en la provincia de Zhejiang, y muchos servicios de transporte fueron cancelados.\",            \"translated_title\": \"Zhejiang detiene actividades\"        },        {            \"english_version\": \"Police reported a gunfire exchange between two people at a festival, and they found two guns at the scene.\",            \"english_title\": \"Gunfire at Festival\",            \"translated_version\": \"La polic\u00eda report\u00f3 un intercambio de disparos entre dos personas en un festival, y encontraron dos armas en el lugar.\",            \"translated_title\": \"Disparos en festival\"        }    ]}"